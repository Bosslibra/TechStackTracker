# Required in production
TRACK_ADMIN_USERNAME=admin

# Create with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('CHANGE_ME'))"
TRACK_ADMIN_PASSWORD_HASH=scrypt:...

# Strong random secret (at least 32 chars)
TRACK_SECRET_KEY=replace-with-a-long-random-secret

# Set to true only when serving over HTTPS
TRACK_COOKIE_SECURE=true

#ENVIRONMENT=production
ENVIRONMENT=development

FLASK_DEBUG=False